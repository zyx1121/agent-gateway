# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to talk to this bot
# Get yours by messaging @userinfobot
ALLOWED_USER_IDS=

# Display name for this agent (shown in /start banner and boot logs).
# The agent's actual personality lives in ~/CLAUDE.md, which Claude Code
# reads natively from the session cwd ($HOME by default).
AGENT_NAME=agent

# Path to claude binary
CLAUDE_BIN=/home/user/.local/bin/claude

# Optional: path to persist sessions metadata (JSON)
SESSIONS_FILE=/home/user/agent-gateway/sessions.json
