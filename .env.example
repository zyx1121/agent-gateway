# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to talk to this bot
# Get yours by messaging @userinfobot
ALLOWED_USER_IDS=

# Path to claude binary
CLAUDE_BIN=/home/user/.local/bin/claude

# Where to spawn each agent's working directory
# A subdir per session will be created: AGENT_HOME/<tg_user_id>/<session_id>/
AGENT_HOME=/home/user/agents

# Optional: path to persist sessions metadata (JSON)
SESSIONS_FILE=/home/user/agent-gateway/sessions.json
